// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      Role     @default(FARMER)
  phone     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  farms     Farm[]
  transactions Transaction[]
}

enum Role {
  FARMER
  MANAGER
  ADMIN
}

model Farm {
  id          String   @id @default(uuid())
  name        String
  location    String?
  sizeHectares Float?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  plots       Plot[]
  transactions Transaction[]
}

model Plot {
  id          String   @id @default(uuid())
  name        String
  sizeHectares Float?
  cropType    String?
  status      PlotStatus @default(IDLE)
  farmId      String
  farm        Farm     @relation(fields: [farmId], references: [id])
  cropCycles  CropCycle[]
  transactions Transaction[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CropCycle {
  id              String   @id @default(uuid())
  plotId          String
  plot            Plot     @relation(fields: [plotId], references: [id])
  cropName        String
  plantedDate     DateTime
  expectedHarvest DateTime?
  actualHarvest   DateTime?
  yieldQuantity   Float?
  yieldUnit       String?
  status          CropStatus @default(PLANTED)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Transaction {
  id          String   @id @default(uuid())
  type        TransactionType
  amount      Float
  category    String
  description String?
  date        DateTime @default(now())
  receiptUrl  String?
  voiceNoteUrl String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  farmId      String?
  farm        Farm?    @relation(fields: [farmId], references: [id])
  plotId      String?
  plot        Plot?    @relation(fields: [plotId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum TransactionType {
  EXPENSE
  INCOME
}

enum CropStatus {
  PLANTED
  GROWING
  READY_TO_HARVEST
  HARVESTED
  FAILED
}

enum PlotStatus {
  IDLE
  PLANTED
  GROWING
  READY_TO_HARVEST
  HARVESTED
}
